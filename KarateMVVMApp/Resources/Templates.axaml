<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:options="using:KarateMVVMApp.Models.Options">
    
    <DataTemplate x:Key="ColorItemTemplate" x:DataType="options:ColorOption">
        <Grid ColumnDefinitions="Auto, *" ColumnSpacing="10">
            <Border Grid.Column="0"
                    Classes="BorderComboBoxColorBox"
                    Background="{Binding HexValue}"/>
            <TextBlock Grid.Column="1"
                       Classes="LoggerSettingTextBlock" 
                       Text="{Binding Name}"/>
        </Grid>
    </DataTemplate>
    
</ResourceDictionary>